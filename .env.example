# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/gastos_gub

# Server configuration
PORT=3600
NODE_ENV=development

# Optional: MongoDB authentication (if using auth)
# MONGODB_USERNAME=your_username
# MONGODB_PASSWORD=your_password

# Gemini API key for the second-stage AI anomaly triage (src/jobs/score-anomalies-ai.ts).
# Google AI Studio → API keys. Uses the cheap gemini-2.5-flash-lite model. Without it
# the triage step is skipped. (Pliego summaries prefer FREE_GEMINI_API_KEY below.)
GEMINI_API_KEY=

# ─── Pliego AI summaries (free-tier model ladder) ────────────────────────────
# The pliego summarizer (shared/pliego/summarize) walks a ladder of FREE models,
# rotating on rate-limit. Free-tier limits are PER MODEL PER PROJECT (not one pool
# for the whole key) on both providers, so more models = more daily headroom.
#
# Primary: Gemini free key (falls back to GEMINI_API_KEY / GOOGLE_API_KEY if unset).
# Each Gemini lite model ≈ 15 RPM · 250k TPM · 1000 RPD of its own.
FREE_GEMINI_API_KEY=
# Fallback: Groq free key (OpenAI-compatible). Used when the Gemini models are
# exhausted. Get one at https://console.groq.com.
FREE_GROQ_API_KEY=
# Ordered, comma-separated model ladders (optional — sensible defaults baked in).
# Free-tier limits are per model per project, so more ids = more daily budget.
# Defaults use ALL free Gemini text models (lite→flash→pro). gemini-3.0-flash-lite
# is omitted because it 404s today; add it when it lists for your key.
# PLIEGO_AI_MODEL (legacy, single id) is prepended to the Gemini list if set.
PLIEGO_GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-2.5-flash,gemini-2.0-flash,gemini-2.5-pro
PLIEGO_GROQ_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b,openai/gpt-oss-20b,qwen/qwen3.6-27b,llama-3.1-8b-instant
# Eager cron tuning: per-run cap and requests/minute (keep RPM < 15 per model).
PLIEGO_EAGER_LIMIT=60
PLIEGO_RPM=10

# ─── Monitor de Llamados + Auth ──────────────────────────────────────────────

# Firebase Admin (SERVER-ONLY — verifies ID tokens, mints the SSR session cookie).
# Firebase console → Project settings → Service accounts → Generate new private key.
# Keep the private key's newlines escaped as \n on a single line.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Web SDK (PUBLIC — exposed to the client for sign-in flows).
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# Email delivery (Resend) for alert / reminder / digest emails.
# Without RESEND_API_KEY the mailer is a no-op (logs, sends nothing).
RESEND_API_KEY=
ALERTS_FROM_EMAIL=alertas@your-verified-domain
# ALERTS_REPLY_TO=

# Public base URL used in alert links (llamado pages, unsubscribe) across all channels.
APP_BASE_URL=http://localhost:3600

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# App/push notifications for llamado alerts. Generate a key pair once with:
#   npx web-push generate-vapid-keys
# Without these the push channel is a no-op and the client hides the push UI.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alertas@gastos.gub.uy
# PUBLIC copy of the public key — the browser needs it to subscribe (SSR-exposed).
NUXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Telegram alerts ─────────────────────────────────────────────────────────
# Create a bot with @BotFather → token + username. Without the token the telegram
# channel is a no-op. TELEGRAM_WEBHOOK_SECRET is echoed in the
# X-Telegram-Bot-Api-Secret-Token header and validated on the webhook.
# TELEGRAM_LINK_SECRET signs the stateless account-linking token (any long random string).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_LINK_SECRET=

# Free-tier cap on watches per user (bounds matcher work).
WATCH_CAP_FREE=10

# Optional tuning
# OPEN_CALLS_BACKFILL_MONTHS=3
# SYNC_EAGER_SUMMARY_LIMIT=10
# PLIEGO_EAGER_LIMIT=20
# AI_TRIAGE_RPM=18

