# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/gastos_gub

# Server configuration
PORT=3600
NODE_ENV=development

# Optional: MongoDB authentication (if using auth)
# MONGODB_USERNAME=your_username
# MONGODB_PASSWORD=your_password

# Gemini API key for the second-stage AI anomaly triage (src/jobs/score-anomalies-ai.ts).
# Google AI Studio → API keys. Uses the cheap gemini-2.5-flash-lite model.
# Without it the statistical detector still runs; only the AI triage is skipped.
GEMINI_API_KEY=

