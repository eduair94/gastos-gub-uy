{
  "name": "gastos_gub-scraper",
  "version": "1.0.0",
  "description": "A TypeScript web scraper following SOLID principles to extract government expenditure data URLs",
  "main": "dist/index.js",
  "scripts": {
    "extract": "tsx src/extract.ts",
    "upload": "tsx src/upload-releases.ts",
    "populate-filters": "tsx src/populate-filters.ts",
    "populate-analytics": "tsx src/populate-analytics.ts",
    "precalculate-dashboard": "tsx src/precalculate-dashboard.ts",
    "refresh-analytics": "tsx src/jobs/refresh-analytics.ts",
    "refresh-product-analytics": "tsx src/jobs/refresh-product-analytics.ts",
    "refresh-product-variants": "tsx src/jobs/refresh-product-variants.ts",
    "detect-anomalies": "tsx src/jobs/detect-anomalies.ts",
    "reconcile-amendments": "tsx src/jobs/reconcile-award-amendments.ts",
    "score-anomalies-ai": "tsx src/jobs/score-anomalies-ai.ts",
    "cross-provider-anomalies": "tsx src/jobs/cross-provider-anomalies.ts",
    "refresh-organism-groups": "tsx src/jobs/refresh-organism-groups.ts",
    "refresh-dept-indicators": "tsx src/jobs/refresh-dept-indicators.ts",
    "build-uruguay-geo": "node scripts/build-uruguay-geo.mjs",
    "import-sice-catalog": "tsx src/jobs/import-sice-catalog.ts",
    "load-dei": "tsx src/jobs/load-dei.ts",
    "sync-open-calls": "tsx src/jobs/sync-open-calls.ts",
    "backfill-open-calls": "tsx src/jobs/backfill-open-calls.ts",
    "deadline-reminders": "tsx src/jobs/deadline-reminders.ts",
    "alert-digest": "tsx src/jobs/alert-digest.ts",
    "webhooks": "tsx src/jobs/webhooks/run.ts",
    "pliego-summary": "tsx src/jobs/pliego-summary.ts",
    "ensure-indexes": "tsx scripts/ensure-indexes.ts",
    "create-text-index": "tsx scripts/create-text-index.ts",
    "update-text-index-exact": "tsx scripts/update-text-index-for-exact-search.ts",
    "export-db": "tsx scripts/export-database.ts",
    "import-db": "tsx scripts/import-database.ts",
    "build": "tsc",
    "create-items": "tsx src/create-items-collection.ts",
    "add_amounts": "tsx src/add-missing-amounts.ts",
    "api": "tsx src/api/app.ts",
    "cronserver": "tsx src/cronserver.ts",
    "cronserver:build": "tsc && node dist/src/cronserver.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "deploy:dashboard": "node scripts/deploy-dashboard.mjs",
    "deploy:dashboard:dry": "node scripts/deploy-dashboard.mjs --dry-run",
    "cronserver:start": "npm run build && pm2 start cronserver.config.js",
    "cronserver:stop": "pm2 stop cronserver.config.js",
    "cronserver:restart": "pm2 restart cronserver.config.js",
    "cronserver:logs": "pm2 logs gastos-gub-cronserver",
    "cronserver:delete": "pm2 delete cronserver.config.js",
    "cronserver:status": "pm2 show gastos-gub-cronserver",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "typescript",
    "web-scraping",
    "solid-principles",
    "government-data",
    "uruguay"
  ],
  "author": "AI Assistant",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^8.2.0",
    "@types/express": "^4.17.21",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/stream-json": "^1.7.8",
    "@types/web-push": "^3.6.4",
    "@types/yauzl": "^2.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@types/mongodb": "^4.0.6",
    "@types/xml2js": "^0.4.14",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.1.0",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "mongodb": "^6.18.0",
    "mongoose": "^8.17.0",
    "mongoose-aggregate-paginate-v2": "^1.1.0",
    "mongoose-paginate-v2": "^1.8.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^9.0.3",
    "resend": "^4.0.0",
    "stream-json": "^1.9.1",
    "unpdf": "^0.12.1",
    "web-push": "^3.6.7",
    "xml2js": "^0.6.2",
    "yauzl": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
